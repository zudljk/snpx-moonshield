---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { entrySlug, formatUtcDate } from "../../utils/format";

export async function getStaticPaths() {
  const entries = await getCollection("log");

  return entries.map((entry) => ({
    params: { slug: entrySlug(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.summary}
  eyebrow="Captain's log"
  summary={entry.data.summary}
  meta={formatUtcDate(entry.data.pubDate)}
  backHref="/log"
  backLabel="Back to log"
>
  <div class="tag-row">
    {entry.data.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
  </div>
  <Content />
</ContentLayout>
