---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  summary?: string;
  meta?: string;
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  description,
  eyebrow,
  summary,
  meta,
  backHref,
  backLabel = "Back"
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="section-heading">
      {backHref && (
        <a class="back-link" href={backHref}>
          {backLabel}
        </a>
      )}
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {summary && <p class="section-intro">{summary}</p>}
      {meta && <p class="meta-line">{meta}</p>}
    </div>
    <article class="content-panel">
      <slot />
    </article>
  </section>
</BaseLayout>
